{
  "name": "@assistifychat/widget",
  "version": "0.1.0",
  "description": "Embed the Assistify chat widget on your site with full TypeScript support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "chat",
    "widget",
    "support",
    "assistify",
    "live-chat"
  ],
  "homepage": "https://assistify.chat/docs/integration/npm-package",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistify-chat/widget-sdk.git"
  },
  "bugs": "https://github.com/assistify-chat/widget-sdk/issues",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "rolldown"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "size-limit",
    "lint:pkg": "publint && node scripts/attw.mjs",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@andrewbranch/untar.js": "^1.0.3",
    "@arethetypeswrong/cli": "^0.18.2",
    "@arethetypeswrong/core": "^0.18.2",
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "fflate": "^0.8.3",
    "jsdom": "^25.0.1",
    "publint": "^0.3.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "size-limit": "^11.1.6",
    "tsdown": "^0.9.6",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "5 kB"
    },
    {
      "path": "dist/react.js",
      "limit": "7 kB"
    }
  ]
}
